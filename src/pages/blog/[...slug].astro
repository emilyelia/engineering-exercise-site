---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content } = await post.render();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Engineering Exercise',
    url: 'https://www.youtube.com/@EngineeringExercise',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Engineering Exercise',
    url: Astro.site?.toString(),
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedAt={post.data.publishedAt}
  updatedAt={post.data.updatedAt}
  jsonLd={jsonLd}
>
  <article class="container page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/blog">Blog</a>
      <span aria-hidden="true"> / </span>
      <span aria-current="page">{post.data.title}</span>
    </nav>

    <header class="post-header">
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
        </div>
      )}
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.publishedAt.toISOString()}>
          {post.data.publishedAt.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {post.data.updatedAt && (
          <span class="updated">
            · Updated {post.data.updatedAt.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
          </span>
        )}
      </div>
    </header>

    <div class="prose post-body">
      <Content />
    </div>

    <a href="/blog" class="back-link">← Back to Blog</a>
  </article>
</BaseLayout>

<style>
  .page {
    padding-top: 2.5rem;
    padding-bottom: 5rem;
    max-width: 740px;
  }

  .breadcrumb {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--accent); }

  .post-header { margin-bottom: 2.5rem; }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tag {
    color: var(--accent);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .post-header h1 {
    font-size: clamp(1.75rem, 4.5vw, 2.625rem);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .post-meta {
    font-size: 0.9rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .post-body {
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
</style>
