---
/**
 * BaseHead — injected into every page's <head>.
 * Handles: meta title, description, canonical URL, Open Graph, Twitter Card,
 * JSON-LD structured data, font preloading, and the Netlify Identity widget
 * (needed for Decap CMS login redirects).
 */
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article' | 'video.other';
  publishedAt?: Date;
  updatedAt?: Date;
  /** Raw JSON-LD object — rendered as <script type="application/ld+json"> */
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  image,
  type = 'website',
  publishedAt,
  updatedAt,
  jsonLd,
} = Astro.props;

const SITE_NAME = 'Engineering Exercise';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;

// Fall back to YouTube thumbnail OG image if none provided
const ogImage = image
  ? (image.startsWith('http') ? image : new URL(image, Astro.site).toString())
  : new URL('/og-default.png', Astro.site).toString();
---

<!-- Charset & viewport must come first -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Canonical URL (prevents duplicate-content penalties) -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary SEO -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />

<!-- Open Graph (Facebook, LinkedIn, Discord, Slack previews) -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content="en_US" />

<!-- Twitter / X Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Article-specific timestamps (used by Google for freshness signals) -->
{publishedAt && (
  <meta property="article:published_time" content={publishedAt.toISOString()} />
)}
{updatedAt && (
  <meta property="article:modified_time" content={updatedAt.toISOString()} />
)}

<!-- JSON-LD Structured Data -->
{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}

<!-- Google Fonts — Inter for clean engineering aesthetic -->
<!-- UPDATE: Change the font URL if you want different fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
  rel="stylesheet"
/>

<!-- Netlify Identity widget — required for Decap CMS /admin login to work -->
<script async src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  // After login, redirect the user back to /admin automatically
  if ((window as any).netlifyIdentity) {
    (window as any).netlifyIdentity.on('init', (user: unknown) => {
      if (!user) {
        (window as any).netlifyIdentity.on('login', () => {
          document.location.href = '/admin/';
        });
      }
    });
  }
</script>
