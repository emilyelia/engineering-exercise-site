---
interface Props {
  id: string;
  title: string;
  thumbnail: string;
  publishedAt: string; // ISO 8601
  hasWriteup?: boolean;
}

const { id, title, thumbnail, publishedAt, hasWriteup = false } = Astro.props;

const displayDate = new Date(publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="video-card">
  <a href={`/videos/${id}`} class="card-link" tabindex="0">
    <div class="thumbnail-wrap">
      <img
        src={thumbnail}
        alt={title}
        loading="lazy"
        decoding="async"
        width="480"
        height="270"
      />
      <span class="play-overlay" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
          <circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.55)" />
          <polygon points="19,15 37,24 19,33" fill="white" />
        </svg>
      </span>
    </div>

    <div class="card-body">
      <h3 class="card-title">{title}</h3>
      <div class="card-meta">
        <time datetime={publishedAt}>{displayDate}</time>
        {hasWriteup && (
          <span class="writeup-badge">Write-up</span>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .video-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .video-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
    border-color: var(--accent);
  }

  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  /* ── Thumbnail ── */
  .thumbnail-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface-2);
  }

  .thumbnail-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .video-card:hover .thumbnail-wrap img {
    transform: scale(1.04);
  }

  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .video-card:hover .play-overlay {
    opacity: 1;
  }

  /* ── Body ── */
  .card-body {
    padding: 0.875rem 1rem 1rem;
  }

  .card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    /* Clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.15s;
  }

  .video-card:hover .card-title {
    color: var(--accent);
  }

  .card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .writeup-badge {
    background: var(--accent);
    color: white;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.125rem 0.5rem;
    border-radius: 100px;
    text-transform: uppercase;
  }
</style>
