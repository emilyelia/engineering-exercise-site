---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-copy">
      &copy; {year} Engineering Exercise. All rights reserved.
    </p>
    <nav class="footer-links" aria-label="Footer navigation">
      <a
        href="https://www.youtube.com/@EngineeringExercise"
        target="_blank"
        rel="noopener noreferrer"
      >
        YouTube
      </a>
      <a href="/blog">Blog</a>
      <a href="/sitemap-index.xml">Sitemap</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 0;
    margin-top: 5rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-copy {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 0;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--text-muted);
    font-size: 0.875rem;
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: var(--text);
    text-decoration: none;
  }
</style>
